pipeline {
    agent any
    tools {
        maven 'Maven 3'
        jdk 'JDK 21 Linux'
    }
    environment {
        DOCKER_IMAGE = "papadooo/freelance-backend:${env.BUILD_NUMBER}"
        SPRING_PROFILES_ACTIVE = 'test'
    }
    stages {
        stage('Compile') {
            steps {
                echo 'Compiling the backend application...'
                sh 'mvn clean compile -DskipTests'
            }
        }
        
        stage('Unit Tests') {
            environment {
                SPRING_PROFILES_ACTIVE = 'test'
                SPRING_DATASOURCE_URL = 'jdbc:h2:mem:testdb'
                SPRING_DATASOURCE_USERNAME = 'sa'
                SPRING_DATASOURCE_PASSWORD = ''
                SPRING_DATASOURCE_DRIVER_CLASS_NAME = 'org.h2.Driver'
                SPRING_JPA_DATABASE_PLATFORM = 'org.hibernate.dialect.H2Dialect'
                SPRING_JPA_HIBERNATE_DDL_AUTO = 'create-drop'
            }
            steps {
                echo 'Running unit tests...'
                sh 'mvn test -Dspring.profiles.active=test'
            }
            post {
                always {
                    junit(
                        allowEmptyResults: true,
                        testResults: '**/target/surefire-reports/*.xml'
                    )
                }
            }
        }
        
        stage('Integration Tests') {
            environment {
                SPRING_PROFILES_ACTIVE = 'test'
                SPRING_DATASOURCE_URL = 'jdbc:h2:mem:integrationtestdb'
                SPRING_DATASOURCE_USERNAME = 'sa'
                SPRING_DATASOURCE_PASSWORD = ''
                SPRING_DATASOURCE_DRIVER_CLASS_NAME = 'org.h2.Driver'
                SPRING_JPA_DATABASE_PLATFORM = 'org.hibernate.dialect.H2Dialect'
                SPRING_JPA_HIBERNATE_DDL_AUTO = 'create-drop'
            }
            steps {
                echo 'Running integration tests...'
                sh 'mvn test-compile'
                sh 'mvn surefire:test -Dtest=TestFreelancerProjectApplicationTests -Dspring.profiles.active=test'
            }
            post {
                always {
                    archiveArtifacts(
                        artifacts: '**/target/surefire-reports/TEST-*TestFreelancerProjectApplicationTests.xml',
                        allowEmptyArchive: true
                    )
                }
            }
        }
        
        stage('Package') {
            steps {
                echo 'Packaging the application...'
                sh 'mvn package -DskipTests'
            }
        }
        
        stage('Build Docker Image') {
            steps {
                echo 'Building Docker image for Minikube...'
                sh 'docker build -t $DOCKER_IMAGE -f docker/Dockerfile.backend.minikube .'
            }
        }
        
        stage('Push Docker Image') {
            steps {
                echo 'Pushing Docker image to Docker Hub...'
                withCredentials([usernamePassword(credentialsId: 'docker-hub-credentials', usernameVariable: 'DOCKER_USERNAME', passwordVariable: 'DOCKER_PASSWORD')]) {
                    sh 'docker login -u $DOCKER_USERNAME -p $DOCKER_PASSWORD'
                    sh 'docker push $DOCKER_IMAGE'
                }
            }
        }
        
        stage('Deploy to Minikube') {
            steps {
                script {
                    // When Jenkins runs in a Docker container, it cannot execute 'minikube ip' from the host.
                    // Instead, we use the special DNS name 'host.docker.internal' which Docker resolves
                    // to the host's internal IP, allowing the container to connect back to services
                    // like the Minikube API server running on the host.
                    withCredentials([file(credentialsId: 'kubeconfig-secret', variable: 'KUBECONFIG_TEMPLATE')]) {
                        
                        echo "📝 Using kubeconfig template from Jenkins credentials..."

                        // Define the Minikube server URL using Docker's special DNS name.
                        // This avoids the need to find the dynamic IP. The standard port is 8443.
                        def minikubeServerUrl = "https://host.docker.internal:8443"
                        echo "➡️  Targeting Minikube server on the host at: ${minikubeServerUrl}"

                        // Create a temporary, updated kubeconfig file by replacing the server URL.
                        def updatedKubeconfigPath = "/tmp/kubeconfig-minikube-updated-${env.BUILD_NUMBER}.yaml"
                        
                        // Use 'sed' to replace the server line in the template.
                        sh "sed -E 's|server:.*|server: ${minikubeServerUrl}|g' ${KUBECONFIG_TEMPLATE} > ${updatedKubeconfigPath}"
                        
                        // Add 'insecure-skip-tls-verify: true' for simplicity in a dev/demo environment,
                        // as the container might not trust the Minikube CA.
                        sh "echo 'insecure-skip-tls-verify: true' >> ${updatedKubeconfigPath}"

                        echo "📄 Generated updated kubeconfig at ${updatedKubeconfigPath}."
                        
                        // Set the KUBECONFIG environment variable for the subsequent steps
                        env.KUBECONFIG = updatedKubeconfigPath
                        
                        echo "🔎 Testing connectivity with updated kubeconfig..."
                        // We add --insecure-skip-tls-verify to kubectl as well, to match the kubeconfig setting.
                        sh 'kubectl cluster-info --kubeconfig=$KUBECONFIG --insecure-skip-tls-verify=true'
                        
                        echo "🚀 Deploying to Minikube using Ansible..."
                        sh 'ansible-playbook ansible/deploy-kubernetes-minikube.yml -i ansible/inventory.yml'
                    }
                }
            }
        }
    }
    post {
        always {
            echo 'Backend Minikube pipeline completed.'
            archiveArtifacts(
                artifacts: '**/target/surefire-reports/*.xml',
                allowEmptyArchive: true
            )
        }
        success {
            echo '✅ Backend deployed successfully to Minikube!'
            echo 'Docker image built and pushed: ' + env.DOCKER_IMAGE
        }
        failure {
            echo '❌ Backend Minikube deployment failed. Check the logs for details.'
        }
    }
} 