pipeline {
    agent any
    tools {
        nodejs 'Node 21'
    }
    environment {
        DOCKER_IMAGE = "papadooo/freelance-frontend:${env.BUILD_NUMBER}"
        CI = 'true'
        GENERATE_SOURCEMAP = 'false'
    }
    stages {
        stage('Checkout') {
            steps {
                echo '🔄 Checking out frontend code...'
                git branch: 'main', url: 'https://github.com/naasssssty/Freelance.git'
            }
        }
        
        stage('Install Dependencies') {
            steps {
                echo '📦 Installing frontend dependencies...'
                dir('frontend') {
                    script {
                        try {
                            // Clean only node_modules, keep package-lock.json for npm ci
                            sh 'rm -rf node_modules || true'
                            
                            // Try npm ci first (faster and more reliable)
                            retry(3) {
                                sh 'npm ci --prefer-offline --timeout=300000'
                            }
                        } catch (Exception e) {
                            echo "npm ci failed, trying npm install as fallback: ${e.getMessage()}"
                            // Only remove package-lock.json if npm ci fails
                            sh 'rm -rf package-lock.json || true'
                            sh 'npm install --timeout=300000'
                        }
                    }
                }
            }
        }
        
        stage('Lint') {
            steps {
                echo '🔍 Running ESLint for code quality...'
                dir('frontend') {
                    script {
                        try {
                            // Try to fix auto-fixable issues first
                            sh 'npm run lint:fix || true'
                            // Then run the actual lint check
                            sh 'npm run lint'
                        } catch (Exception e) {
                            echo "ESLint found issues: ${e.getMessage()}"
                            // Don't fail the build for linting issues, just warn
                            sh 'npm run lint || true'
                        }
                    }
                }
            }
        }
        
        stage('Unit Tests') {
            environment {
                // Jest test environment
                CI = 'true'
                NODE_ENV = 'test'
            }
            steps {
                echo '🧪 Running unit tests...'
                dir('frontend') {
                    // Use the new test:ci script
                    sh 'npm run test:ci'
                }
            }
            post {
                always {
                    // Archive coverage reports as artifacts for now
                    script {
                        try {
                            archiveArtifacts(
                                artifacts: 'frontend/coverage/**/*',
                                allowEmptyArchive: true
                            )
                            echo "✅ Coverage reports archived successfully"
                        } catch (Exception e) {
                            echo "Could not archive coverage reports: ${e.getMessage()}"
                        }
                    }
                }
            }
        }
        
        stage('Integration Tests') {
            environment {
                // Integration test environment
                CI = 'true'
                NODE_ENV = 'test'
                REACT_APP_API_URL = 'http://localhost:8080'
            }
            steps {
                echo '🔗 Running integration tests...'
                dir('frontend') {
                    script {
                        try {
                            // Run integration tests with coverage
                            sh 'npm run test:integration:coverage'
                        } catch (Exception e) {
                            echo "Integration tests failed: ${e.getMessage()}"
                            // Don't fail the pipeline for integration test failures in development
                            sh 'echo "Integration tests completed with issues"'
                        }
                    }
                }
            }
            post {
                always {
                    // Archive integration test results
                    archiveArtifacts(
                        artifacts: 'frontend/coverage/**/*',
                        allowEmptyArchive: true
                    )
                }
            }
        }
        
        stage('Build') {
            steps {
                echo '🏗️ Building frontend application...'
                dir('frontend') {
                    sh 'npm run build'
                }
            }
            post {
                always {
                    // Archive build artifacts
                    archiveArtifacts(
                        artifacts: 'frontend/build/**/*',
                        allowEmptyArchive: true
                    )
                }
            }
        }
        
        stage('Security Audit') {
            steps {
                echo '🔒 Running security audit...'
                dir('frontend') {
                    sh 'npm audit --audit-level=moderate || true'
                }
            }
        }
        
        stage('Build Docker Image') {
            steps {
                echo '🐳 Building Docker image for Minikube...'
                sh 'docker build -t $DOCKER_IMAGE -f docker/Dockerfile.frontend.minikube frontend/'
            }
        }
        
        stage('Push Docker Image') {
            steps {
                echo '📤 Pushing Docker image to Docker Hub...'
                withCredentials([usernamePassword(credentialsId: 'docker-hub-credentials', usernameVariable: 'DOCKER_USERNAME', passwordVariable: 'DOCKER_PASSWORD')]) {
                    sh 'docker login -u $DOCKER_USERNAME -p $DOCKER_PASSWORD'
                    sh 'docker push $DOCKER_IMAGE'
                }
            }
        }
        
        stage('Deploy to Minikube') {
            steps {
                script {
                    // When Jenkins runs in a Docker container, it cannot execute 'minikube ip' from the host.
                    // Instead, we use the special DNS name 'host.docker.internal' which Docker resolves
                    // to the host's internal IP, allowing the container to connect back to services
                    // like the Minikube API server running on the host.
                    withCredentials([file(credentialsId: 'kubeconfig-secret', variable: 'KUBECONFIG_TEMPLATE')]) {
                        
                        echo "📝 Using kubeconfig template from Jenkins credentials..."

                        // Define the Minikube server URL using Docker's special DNS name.
                        // This avoids the need to find the dynamic IP. The standard port is 8443.
                        def minikubeServerUrl = "https://host.docker.internal:8443"
                        echo "➡️  Targeting Minikube server on the host at: ${minikubeServerUrl}"

                        // Create a temporary, updated kubeconfig file by replacing the server URL.
                        def updatedKubeconfigPath = "/tmp/kubeconfig-minikube-updated-${env.BUILD_NUMBER}.yaml"
                        
                        // Use 'sed' to replace the server line in the template.
                        sh "sed -E 's|server:.*|server: ${minikubeServerUrl}|g' ${KUBECONFIG_TEMPLATE} > ${updatedKubeconfigPath}"
                        
                        // Add 'insecure-skip-tls-verify: true' for simplicity in a dev/demo environment,
                        // as the container might not trust the Minikube CA.
                        sh "echo 'insecure-skip-tls-verify: true' >> ${updatedKubeconfigPath}"
                        
                        echo "📄 Generated updated kubeconfig at ${updatedKubeconfigPath}."
                        
                        // Set the KUBECONFIG environment variable for the subsequent steps
                        env.KUBECONFIG = updatedKubeconfigPath
                        
                        echo "🔎 Testing connectivity with updated kubeconfig..."
                        // We add --insecure-skip-tls-verify to kubectl as well, to match the kubeconfig setting.
                        sh 'kubectl cluster-info --kubeconfig=$KUBECONFIG --insecure-skip-tls-verify=true'
                        
                        echo "🚀 Deploying to Minikube using Ansible..."
                        sh 'ansible-playbook ansible/deploy-kubernetes-minikube.yml -i ansible/inventory.yml'
                    }
                }
            }
        }
    }
    post {
        always {
            echo '🏁 Frontend Minikube pipeline completed.'
            // Archive test reports
            archiveArtifacts(
                artifacts: 'frontend/coverage/**/*',
                allowEmptyArchive: true
            )
        }
        success {
            echo '✅ Frontend deployed successfully to Minikube!'
            echo 'Docker image built and pushed: ' + env.DOCKER_IMAGE
        }
        failure {
            echo '❌ Frontend Minikube deployment failed. Check the logs for details.'
        }
    }
} 